# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Required for LLM extraction
GOOGLE_API_KEY=your-api-key-here

# Alert channels (set when alerts.enabled=true in config.yaml)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# Email alerts (SMTP)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=alerts@example.com
# SMTP_PASSWORD=your-smtp-password
# ALERT_EMAIL_FROM=rivalsense@example.com
# ALERT_EMAIL_TO=analyst@example.com

# Dashboard auth (when auth.provider=basic in config.yaml)
# DASHBOARD_PASSWORD=your-dashboard-password
